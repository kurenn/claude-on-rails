# Generated by ClaudeOnRails CI generator
# This workflow runs read-only review agents on pull requests.
#
# Required secrets:
#   ANTHROPIC_API_KEY - Your Anthropic API key
#
# Review agents: <%= options[:review_agents].join(', ') %>

name: Claude Review

on:
  pull_request:
    types: [opened, synchronize]

permissions:
  contents: read
  pull-requests: write

jobs:
  claude-review:
    runs-on: ubuntu-latest
    env:
      ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up Ruby
        uses: ruby/setup-ruby@v1
        with:
          ruby-version: .ruby-version
          bundler-cache: true

      - name: Install claude-swarm
        run: gem install claude_swarm --version '~> 1.0'

      - name: Run review agents
        run: |
          claude-swarm start --stream-logs -p \
            "Review the changes in this PR using the <%= options[:review_agents].join(', ') %> agents. Focus only on reading and reviewing — do not make any changes. Here are the changed files: $(git diff --name-only origin/${{ github.event.pull_request.base.ref }}...HEAD)" \
            | tee review-output.txt

      - name: Post review comment
        if: always()
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            let reviewOutput = 'Review completed. Check the workflow logs for details.';
            try {
              const raw = fs.readFileSync('review-output.txt', 'utf8');
              reviewOutput = raw.slice(-10000);
            } catch (e) {
              console.log('No output file found, using default message');
            }
            await github.rest.issues.createComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.payload.pull_request.number,
              body: `## Claude Review\n\n\`\`\`\n${reviewOutput}\n\`\`\``
            });
