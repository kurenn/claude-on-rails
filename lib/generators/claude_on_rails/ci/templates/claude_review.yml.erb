# Generated by ClaudeOnRails CI generator
# This workflow runs read-only review agents on pull requests.
#
# Required secrets:
#   ANTHROPIC_API_KEY - Your Anthropic API key
#
# Review agents: <%= options[:review_agents].join(', ') %>
#
# Note: claude-swarm does not currently support running individual agents
# selectively. This workflow runs a non-interactive review prompt against
# the full swarm, asking only the review agents to participate.

name: Claude Design & Security Review

on:
  pull_request:
    types: [opened, synchronize]

permissions:
  contents: read
  pull-requests: write

jobs:
  claude-review:
    runs-on: ubuntu-latest
    env:
      ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up Ruby
        uses: ruby/setup-ruby@v1
        with:
          bundler-cache: true

      - name: Install claude-swarm
        run: gem install claude_swarm

      - name: Run review agents
        run: |
          echo "Running read-only review for PR #${{ github.event.pull_request.number }}"
          REVIEW_AGENTS="<%= options[:review_agents].join(', ') %>"
          DIFF=$(git diff origin/${{ github.event.pull_request.base.ref }}...HEAD)
          cat <<PROMPT | claude-swarm --non-interactive
          Please have the following agents review the changes in this PR: ${REVIEW_AGENTS}.
          Focus only on reading and reviewing - do not make any changes.

          Here is the diff:
          ${DIFF}
          PROMPT

      - name: Post review comment
        if: always()
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            // claude-swarm logs output to claude-swarm.log
            let reviewOutput = 'Review completed. Check the workflow logs for details.';
            try {
              reviewOutput = fs.readFileSync('claude-swarm.log', 'utf8').slice(-4000);
            } catch (e) {
              console.log('No log file found, using default message');
            }
            await github.rest.issues.createComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.payload.pull_request.number,
              body: `## Claude Review\n\n\`\`\`\n${reviewOutput}\n\`\`\``
            });
