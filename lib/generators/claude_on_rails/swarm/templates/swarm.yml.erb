version: 1
swarm:
  name: "<%= Rails.application.class.module_parent_name %> Rails Development Team"
  main: architect
  instances:
    architect:
      description: "Rails architect coordinating <%= @api_only ? 'API' : 'full-stack' %> development for <%= Rails.application.class.module_parent_name %>"
      directory: .
      model: <%= @agent_models['architect'] || @default_model %>
      connections: [<%= agents.reject { |a| a == 'architect' }.join(', ') %>]
      prompt_file: .claude-on-rails/prompts/architect.md
      vibe: true
<%- if @include_mcp_server -%>
      mcps:
        - name: rails
          type: stdio
          command: rails-mcp-server
          args: []
          env:
            RAILS_ENV: <%= Rails.env %>
<%- if @include_dev_mcp -%>
        - name: rails-dev
          type: stdio
          command: rails-dev-mcp
          args: []
<%- end -%>
<%- end -%>
<%- if File.directory?(Rails.root.join("app/models")) -%>

    models:
      description: "ActiveRecord models, migrations, and database optimization specialist"
      directory: ./app/models
      model: <%= @agent_models['models'] || @default_model %>
      connections: [database]
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/models.md
<%- if @include_mcp_server -%>
      mcps:
        - name: rails
          type: stdio
          command: rails-mcp-server
          args: []
          env:
            RAILS_ENV: <%= Rails.env %>
<%- end -%>
<%- end -%>

    database:
      description: "Database schema design, query optimization, and N+1 detection specialist"
      directory: .
      model: <%= @agent_models['database'] || @default_model %>
      connections: [models]
      allowed_tools: [Read, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/database.md
<%- if File.directory?(Rails.root.join("app/controllers")) -%>

    controllers:
      description: "Rails controllers, routing, and request handling specialist"
      directory: ./app/controllers
      model: <%= @agent_models['controllers'] || @default_model %>
<%- connections = [] -%>
<%- connections << 'services' if File.directory?(Rails.root.join("app/services")) -%>
<%- connections << 'api' if @api_only && File.directory?(Rails.root.join("app/controllers/api")) -%>
<%- if connections.any? -%>
      connections: [<%= connections.join(', ') %>]
<%- end -%>
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/controllers.md
<%- if @include_mcp_server -%>
      mcps:
        - name: rails
          type: stdio
          command: rails-mcp-server
          args: []
          env:
            RAILS_ENV: <%= Rails.env %>
<%- end -%>
<%- end -%>
<%- if !@api_only && File.directory?(Rails.root.join("app/views")) -%>

    views:
      description: "Rails views, layouts, partials,<%= @has_view_component ? ' ViewComponent,' : '' %> and asset pipeline specialist"
      directory: ./app/views
      model: <%= @agent_models['views'] || @default_model %>
<%- view_connections = [] -%>
<%- view_connections << 'stimulus' if @has_turbo && File.directory?(Rails.root.join("app/javascript")) -%>
<%- view_connections << 'tailwind' if @has_tailwind -%>
<%- view_connections << 'i18n' if @has_i18n && File.directory?(Rails.root.join("config/locales")) -%>
<%- if view_connections.any? -%>
      connections: [<%= view_connections.join(', ') %>]
<%- end -%>
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/views.md
<%- if @include_mcp_server -%>
      mcps:
        - name: rails
          type: stdio
          command: rails-mcp-server
          args: []
          env:
            RAILS_ENV: <%= Rails.env %>
<%- end -%>
<%- end -%>
<%- if @api_only && File.directory?(Rails.root.join("app/controllers/api")) -%>

    api:
      description: "RESTful API design, serialization, and versioning specialist"
      directory: ./app/controllers/api
      model: <%= @agent_models['api'] || @default_model %>
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/api.md
<%- end -%>
<%- if @has_graphql && File.directory?(Rails.root.join("app/graphql")) -%>

    graphql:
      description: "GraphQL schema, resolvers, and mutations specialist"
      directory: ./app/graphql
      model: <%= @agent_models['graphql'] || @default_model %>
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/graphql.md
<%- end -%>
<%- if @has_turbo && File.directory?(Rails.root.join("app/javascript")) -%>

    stimulus:
      description: "Stimulus.js controllers and Turbo integration specialist"
      directory: ./app/javascript
      model: <%= @agent_models['stimulus'] || @default_model %>
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/stimulus.md
<%- end -%>
<%- if @has_tailwind -%>

    tailwind:
      description: "Tailwind CSS styling, responsive design, and Rails frontend integration specialist"
      directory: .
      model: <%= @agent_models['tailwind'] || @default_model %>
<%- tailwind_connections = ['views'] -%>
<%- tailwind_connections << 'stimulus' if @has_turbo && File.directory?(Rails.root.join("app/javascript")) -%>
      connections: [<%= tailwind_connections.join(', ') %>]
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/tailwind.md
<%- end -%>
<%- if File.directory?(Rails.root.join("app/services")) -%>

    services:
      description: "Service objects, business logic, and design patterns specialist"
      directory: ./app/services
      model: <%= @agent_models['services'] || @default_model %>
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/services.md
<%- end -%>
<%- if File.directory?(Rails.root.join("app/jobs")) -%>

    jobs:
      description: "Background jobs, ActiveJob, and async processing specialist"
      directory: ./app/jobs
      model: <%= @agent_models['jobs'] || @default_model %>
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/jobs.md
<%- end -%>
<%- if !@skip_tests -%>
<%- test_dir = @test_framework == 'RSpec' ? 'spec' : 'test' -%>
<%- if File.directory?(Rails.root.join(test_dir)) -%>

    tests:
      description: "<%= @test_framework %> testing, factories, and test coverage specialist"
      directory: ./<%= test_dir %>
      model: <%= @agent_models['tests'] || @default_model %>
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/tests.md
<%- if @include_mcp_server -%>
      mcps:
        - name: rails
          type: stdio
          command: rails-mcp-server
          args: []
          env:
            RAILS_ENV: <%= Rails.env %>
<%- end -%>
<%- end -%>
<%- end -%>
<%- if @has_i18n && File.directory?(Rails.root.join("config/locales")) -%>

    i18n:
      description: "Rails internationalization, localization, and translation specialist"
      directory: ./config/locales
      model: <%= @agent_models['i18n'] || @default_model %>
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/i18n.md
<%- end -%>
<%- if File.directory?(Rails.root.join("config")) -%>

    devops:
      description: "Deployment, Docker, CI/CD, and production configuration specialist"
      directory: ./config
      model: <%= @agent_models['devops'] || @default_model %>
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/devops.md
<%- end -%>
<%- if @has_boorails -%>

    security:
      description: "Application security auditing specialist powered by BooRails"
      directory: .
      model: <%= @agent_models['security'] || @default_model %>
      connections: [<%= @api_only ? 'models, controllers, api' : 'models, controllers, views' %>]
      allowed_tools: [Read, Edit, Write, Bash, Grep, Glob, LS]
      prompt_file: .claude-on-rails/prompts/security.md
<%- end -%>
